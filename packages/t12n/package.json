{
  "name": "@dnssfnv/t12n",
  "version": "0.1.1",
  "description": "Type-driven runtime validation (t12n) — turn your TypeScript types into runtime validators.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denis-sofonov/t12n.git",
    "directory": "packages/t12n"
  },
  "homepage": "https://t12n.vercel.app",
  "bugs": "https://github.com/denis-sofonov/t12n/issues",
  "keywords": [
    "t12n",
    "typescript",
    "validation",
    "runtime",
    "vite-plugin",
    "webpack",
    "unplugin",
    "react",
    "vue",
    "svelte",
    "solid",
    "types",
    "schema",
    "type-safe",
    "zod-alternative"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack.d.ts",
        "default": "./dist/webpack.js"
      },
      "require": {
        "types": "./dist/webpack.d.cts",
        "default": "./dist/webpack.cjs"
      }
    },
    "./rollup": {
      "import": {
        "types": "./dist/rollup.d.ts",
        "default": "./dist/rollup.js"
      },
      "require": {
        "types": "./dist/rollup.d.cts",
        "default": "./dist/rollup.cjs"
      }
    },
    "./esbuild": {
      "import": {
        "types": "./dist/esbuild.d.ts",
        "default": "./dist/esbuild.js"
      },
      "require": {
        "types": "./dist/esbuild.d.cts",
        "default": "./dist/esbuild.cjs"
      }
    },
    "./rspack": {
      "import": {
        "types": "./dist/rspack.d.ts",
        "default": "./dist/rspack.js"
      },
      "require": {
        "types": "./dist/rspack.d.cts",
        "default": "./dist/rspack.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "vite": [
        "./dist/vite.d.ts"
      ],
      "webpack": [
        "./dist/webpack.d.ts"
      ],
      "rollup": [
        "./dist/rollup.d.ts"
      ],
      "esbuild": [
        "./dist/esbuild.d.ts"
      ],
      "rspack": [
        "./dist/rspack.d.ts"
      ],
      "runtime": [
        "./dist/runtime.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bench": "pnpm bench:runtime && pnpm bench:codegen",
    "bench:runtime": "tsx bench/runtime.bench.mjs",
    "bench:codegen": "tsx bench/codegen.bench.mjs",
    "prepublishOnly": "vitest run && tsc --noEmit",
    "prepack": "tsup"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "magic-string": "^0.30.0",
    "ts-morph": "^25.0.0",
    "unplugin": "^2.0.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
