---
import Base from './Base.astro'
import { sidebars, ui, neighbours, norm } from '../nav'

interface Heading { depth: number; slug: string; text: string }
interface Frontmatter { title?: string; description?: string; lang?: 'en' | 'ru' }

const { frontmatter, headings = [] } = Astro.props as { frontmatter: Frontmatter; headings: Heading[] }
const lang = frontmatter.lang ?? 'en'
const groups = sidebars[lang]
const t = ui[lang]
const path = norm(Astro.url.pathname)
const { prev, next } = neighbours(lang, path)
const outline = headings.filter((h) => h.depth === 2 || h.depth === 3)
---

<Base title={frontmatter.title ? `${frontmatter.title} — t12n` : undefined} description={frontmatter.description} lang={lang}>
  <div class="doc wrap">
    <aside class="doc__side" id="doc-side">
      <button class="side__toggle" id="side-toggle" aria-expanded="false" aria-controls="doc-side-nav">
        <span>{t.menu}</span>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <nav class="side" id="doc-side-nav">
        {groups.map((g) => (
          <div class="side__group">
            <p class="side__title">{g.text}</p>
            <ul class="side__list">
              {g.items.map((it) => (
                <li>
                  <a href={it.link} class={norm(it.link) === path ? 'is-active' : ''} aria-current={norm(it.link) === path ? 'page' : undefined}>{it.text}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <article class="doc__main prose" data-pagefind-body>
      <slot />
      <nav class="pager">
        {prev ? <a class="pager__link pager__link--prev" href={prev.link}><span class="pager__dir">{t.prev}</span><span class="pager__txt">{prev.text}</span></a> : <span></span>}
        {next ? <a class="pager__link pager__link--next" href={next.link}><span class="pager__dir">{t.next}</span><span class="pager__txt">{next.text}</span></a> : <span></span>}
      </nav>
    </article>

    <aside class="doc__outline">
      {outline.length > 0 && (
        <nav class="toc" aria-label={t.onThisPage}>
          <p class="toc__title">{t.onThisPage}</p>
          <ul>
            {outline.map((h) => (
              <li class={h.depth === 3 ? 'toc__sub' : ''}><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ul>
        </nav>
      )}
    </aside>
  </div>
</Base>

<style>
  .doc {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr) 200px;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
    padding-top: 2.5rem;
  }
  /* sidebar */
  .doc__side { position: sticky; top: 72px; align-self: start; max-height: calc(100svh - 88px); overflow-y: auto; }
  .side__toggle {
    display: none; width: 100%; align-items: center; justify-content: space-between;
    background: var(--card); border: 1px solid var(--line); border-radius: var(--radius-sm);
    padding: 0.6rem 0.9rem; cursor: pointer; color: var(--ink);
    font-family: var(--font-mono); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em;
  }
  .side__toggle svg { transition: transform 0.2s var(--ease); color: var(--ink-3); }
  #doc-side.open .side__toggle svg { transform: rotate(180deg); }
  .side__group { margin-bottom: 1.5rem; }
  .side__title {
    font-family: var(--font-mono); font-size: 0.68rem; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--ink-3); margin-bottom: 0.55rem; padding-left: 0.65rem;
  }
  .side__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.1rem; }
  .side__list a {
    display: block; padding: 0.32rem 0.65rem;
    font-size: 0.88rem; color: var(--ink-2); border-radius: 6px;
    transition: background 0.16s var(--ease), color 0.16s var(--ease);
  }
  .side__list a:hover { background: var(--accent-soft); color: var(--accent); }
  .side__list a.is-active { color: var(--accent); font-weight: 500; background: var(--accent-soft); }

  /* main */
  .doc__main { min-width: 0; padding-bottom: 2rem; }

  /* outline */
  .doc__outline { position: sticky; top: 72px; align-self: start; }
  .toc__title {
    font-family: var(--font-mono); font-size: 0.68rem; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--ink-3); margin-bottom: 0.6rem;
  }
  .toc ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.15rem; border-left: 1px solid var(--line); }
  .toc a {
    display: block; padding: 0.2rem 0 0.2rem 0.8rem; margin-left: -1px;
    font-size: 0.8rem; color: var(--ink-3); border-left: 1px solid transparent;
    transition: color 0.16s var(--ease), border-color 0.16s var(--ease);
  }
  .toc a:hover { color: var(--accent); border-left-color: var(--accent); }
  .toc a.is-active { color: var(--accent); border-left-color: var(--accent); font-weight: 500; }
  .toc__sub a { padding-left: 1.5rem; font-size: 0.76rem; }

  /* pager */
  .pager { display: flex; justify-content: space-between; gap: 1rem; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--line); }
  .pager__link {
    display: flex; flex-direction: column; gap: 0.2rem; flex: 1; max-width: 48%;
    padding: 0.85rem 1.1rem; border: 1px solid var(--line); border-radius: var(--radius-sm);
    background: var(--card); transition: border-color 0.18s var(--ease), transform 0.18s var(--ease);
  }
  .pager__link:hover { border-color: var(--accent); transform: translateY(-2px); }
  .pager__link--next { text-align: right; }
  .pager__dir { font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-3); }
  .pager__txt { font-size: 0.95rem; font-weight: 500; color: var(--accent); }

  /* responsive */
  @media (max-width: 1080px) {
    .doc { grid-template-columns: 200px minmax(0, 1fr); }
    .doc__outline { display: none; }
  }
  @media (max-width: 760px) {
    .doc { grid-template-columns: 1fr; padding-top: 1.5rem; }
    .doc__side {
      position: static; max-height: none; overflow: visible; margin-bottom: 1.5rem;
    }
    .side__toggle { display: flex; }
    .doc__side .side { display: none; padding-top: 1rem; }
    #doc-side.open .side { display: block; }
  }

  /* copy button on prose code blocks (injected by copyCode) */
  .doc__main :global(.code-block) { position: relative; margin: 1.25rem 0; }
  .doc__main :global(.code-block pre.astro-code) { margin: 0; }
  .doc__main :global(.code-copy) {
    position: absolute; top: 0.5rem; right: 0.5rem;
    display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px; padding: 0;
    background: var(--card); border: 1px solid var(--line); border-radius: 7px;
    color: var(--ink-3); cursor: pointer; opacity: 0;
    transition: opacity 0.16s var(--ease), color 0.16s var(--ease), border-color 0.16s var(--ease), background 0.16s var(--ease);
  }
  .doc__main :global(.code-block:hover .code-copy),
  .doc__main :global(.code-copy:focus-visible) { opacity: 1; }
  .doc__main :global(.code-copy:hover) { color: var(--accent); border-color: var(--accent); }
  .doc__main :global(.code-copy.is-copied) { opacity: 1; color: #fff; background: var(--accent); border-color: var(--accent); }
  .doc__main :global(.code-copy .ic-copy),
  .doc__main :global(.code-copy .ic-done) { display: inline-flex; }
  .doc__main :global(.code-copy .ic-done) { display: none; }
  .doc__main :global(.code-copy.is-copied .ic-copy) { display: none; }
  .doc__main :global(.code-copy.is-copied .ic-done) { display: inline-flex; }
  @media (hover: none) { .doc__main :global(.code-copy) { opacity: 1; } }
</style>

<script>
  // "On this page" scrollspy — highlight the section nearest the top.
  let detach: (() => void) | null = null

  function spy() {
    detach?.()
    const toc = document.querySelector('.toc')
    if (!toc) return
    const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>('a'))
    const byId = new Map(links.map((a) => [decodeURIComponent(a.hash.slice(1)), a]))
    const heads = Array.from(
      document.querySelectorAll<HTMLElement>('.prose h2[id], .prose h3[id]'),
    ).filter((h) => byId.has(h.id))
    if (heads.length === 0) return

    let active: HTMLAnchorElement | null = null
    const update = () => {
      let cur = heads[0]
      for (const h of heads) {
        if (h.getBoundingClientRect().top <= 92) cur = h
        else break
      }
      const link = byId.get(cur.id) ?? null
      if (link !== active) {
        active?.classList.remove('is-active')
        link?.classList.add('is-active')
        active = link
      }
    }

    let ticking = false
    const onScroll = () => {
      if (ticking) return
      ticking = true
      requestAnimationFrame(() => { update(); ticking = false })
    }
    document.addEventListener('scroll', onScroll, { passive: true })
    update()
    detach = () => document.removeEventListener('scroll', onScroll)
  }

  function sideToggle() {
    const side = document.getElementById('doc-side')
    const btn = document.getElementById('side-toggle')
    if (!side || !btn) return
    btn.addEventListener('click', () => {
      const open = side.classList.toggle('open')
      btn.setAttribute('aria-expanded', String(open))
    })
    // collapse again after picking a page on mobile
    side.querySelectorAll('.side a').forEach((a) =>
      a.addEventListener('click', () => { side.classList.remove('open'); btn.setAttribute('aria-expanded', 'false') }),
    )
  }

  // Copy button on every prose code block (install command and all snippets).
  function copyCode() {
    const ru = document.documentElement.lang === 'ru'
    const COPY = '<svg viewBox="0 0 24 24" width="14" height="14"><rect x="9" y="9" width="11" height="11" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>'
    const DONE = '<svg viewBox="0 0 24 24" width="14" height="14"><path d="M5 12l5 5L20 7" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>'
    document.querySelectorAll<HTMLPreElement>('.prose pre.astro-code').forEach((pre) => {
      if (pre.dataset.copyReady) return
      pre.dataset.copyReady = '1'
      const text = (pre.querySelector('code') ?? pre).textContent ?? ''

      const wrap = document.createElement('div')
      wrap.className = 'code-block'
      pre.parentNode?.insertBefore(wrap, pre)
      wrap.appendChild(pre)

      const btn = document.createElement('button')
      btn.type = 'button'
      btn.className = 'code-copy'
      btn.setAttribute('aria-label', ru ? 'Скопировать' : 'Copy')
      btn.innerHTML = `<span class="ic-copy">${COPY}</span><span class="ic-done">${DONE}</span>`
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(text)
          btn.classList.add('is-copied')
          setTimeout(() => btn.classList.remove('is-copied'), 1400)
        } catch {}
      })
      wrap.appendChild(btn)
    })
  }

  document.addEventListener('astro:page-load', () => { spy(); sideToggle(); copyCode() })
  document.addEventListener('astro:before-swap', () => detach?.())
</script>
