---
import { Code } from 'astro:components'

interface Props { lang?: 'en' | 'ru' }
const { lang = 'en' } = Astro.props

const typeCode = `type User = {
  id: number
  name: string
  email: string
  role: 'admin' | 'user'
  address: { zip: string }
}`

const schemaCode = `{ kind: 'object', properties: {
  id:      { kind: 'number' },
  name:    { kind: 'string' },
  email:   { kind: 'string' },
  role:    { kind: 'enum', values: ['admin', 'user'] },
  address: { kind: 'object', properties: { zip: { kind: 'string' } } },
} }`

const t = lang === 'ru'
  ? {
      type: 'Тип', ro: 'read-only', data: 'Данные',
      run: 'Проверить ▸', schema: 'Выведенная схема',
      presets: { valid: 'валидно', wrongType: 'не тот тип', missing: 'нет поля', extra: 'лишние ключи', multi: 'много ошибок' },
      consoleTitle: 'Консоль', hint: 'Нажмите «Проверить» — результат появится здесь (и в консоли браузера).',
    }
  : {
      type: 'The type', ro: 'read-only', data: 'Your data',
      run: 'Validate ▸', schema: 'Derived schema',
      presets: { valid: 'valid', wrongType: 'wrong type', missing: 'missing field', extra: 'extra keys', multi: 'many errors' },
      consoleTitle: 'Console', hint: 'Hit “Validate” — the result shows here (and in the browser console).',
    }
---

<section class="pg" data-lang={lang}>
  <div class="pg__grid">
    <div class="pg__col">
      <p class="pg__cap"><span class="pg__cap-dot" aria-hidden="true"></span>{t.type}<span class="pg__cap-note">{t.ro}</span></p>
      <div class="pg__block"><div class="pg__code"><Code code={typeCode} lang="ts" theme="vitesse-light" /></div></div>
    </div>

    <div class="pg__col">
      <div class="pg__cap pg__cap--data">
        <span class="pg__cap-main"><span class="pg__cap-dot pg__cap-dot--ok" aria-hidden="true"></span>{t.data}</span>
        <span class="pg__presets">
          <button type="button" data-preset="valid">{t.presets.valid}</button>
          <button type="button" data-preset="wrongType">{t.presets.wrongType}</button>
          <button type="button" data-preset="missing">{t.presets.missing}</button>
          <button type="button" data-preset="extra">{t.presets.extra}</button>
          <button type="button" data-preset="multi">{t.presets.multi}</button>
        </span>
      </div>
      <div class="pg__block"><textarea class="pg__input" spellcheck="false" autocomplete="off" autocapitalize="off"></textarea></div>
    </div>
  </div>

  <details class="pg__schema">
    <summary>{t.schema}</summary>
    <div class="pg__code pg__code--schema"><Code code={schemaCode} lang="ts" theme="vitesse-light" /></div>
  </details>

  <div class="pg__console">
    <div class="pg__cap pg__cap--console">
      <span class="pg__cap-main"><span class="pg__cap-dot pg__cap-dot--ok" aria-hidden="true"></span>{t.consoleTitle}</span>
      <button type="button" class="pg__run">{t.run}</button>
    </div>
    <div class="pg__out" aria-live="polite"><span class="pg__hint">{t.hint}</span></div>
  </div>
</section>

<style>
  .pg { margin-top: 1.5rem; }
  .pg__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; align-items: stretch; }
  @media (max-width: 820px) { .pg__grid { grid-template-columns: 1fr; } }

  /* two columns → caption above, bordered block below; tops/bottoms align */
  .pg__col { display: flex; flex-direction: column; min-width: 0; }

  /* caption above each block — same voice as the hero file name */
  .pg__cap { display: flex; align-items: center; gap: 0.5rem; margin: 0 0.15rem 0.55rem; font-family: var(--font-mono); font-size: 0.74rem; color: var(--ink-2); letter-spacing: 0.01em; }
  .pg__cap-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--ink-3); flex-shrink: 0; }
  .pg__cap-dot--ok { background: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); }
  .pg__cap-note { margin-left: auto; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.68rem; }
  .pg__cap--data { flex-wrap: wrap; gap: 0.45rem 0.6rem; }
  .pg__cap-main { display: inline-flex; align-items: center; gap: 0.5rem; }

  .pg__presets { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-left: auto; }
  .pg__presets button {
    font-family: var(--font-mono); font-size: 0.7rem; color: var(--ink-2);
    background: var(--card); border: 1px solid var(--line); border-radius: 6px;
    padding: 0.22rem 0.5rem; cursor: pointer; transition: color 0.16s var(--ease), border-color 0.16s var(--ease); white-space: nowrap;
  }
  .pg__presets button:hover { border-color: var(--accent); color: var(--accent); }

  /* the block itself is the bordered card now (no inner header bar) */
  .pg__block { flex: 1; display: flex; min-height: 212px; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--card); overflow: hidden; transition: border-color 0.16s var(--ease), box-shadow 0.16s var(--ease); }
  .pg__block:focus-within { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); }
  .pg__code { flex: 1; display: flex; min-width: 0; }
  .pg__code :global(pre.astro-code) { flex: 1; margin: 0 !important; border: 0 !important; border-radius: 0 !important; background: var(--card) !important; padding: 0.85rem 1rem; font-size: 0.8rem; }
  .pg__input {
    flex: 1; min-width: 0; resize: none; width: 100%; display: block;
    font-family: var(--font-mono); font-size: 0.8rem; line-height: 1.6; color: var(--ink);
    background: var(--card); border: 0; border-radius: 0; padding: 0.85rem 1rem; tab-size: 2;
  }
  .pg__input:focus { outline: none; }

  /* Validate lives on the console caption — right above where the result shows,
     so there's no empty action row. */
  .pg__console { margin-top: 1.4rem; }
  .pg__cap--console { gap: 0.6rem; flex-wrap: wrap; align-items: center; }
  .pg__run {
    margin-left: auto; font-family: var(--font-body); font-size: 0.82rem; font-weight: 500;
    color: #fff; background: var(--accent); border: 1px solid var(--accent); border-radius: 8px;
    padding: 0.36rem 1rem; cursor: pointer; transition: background 0.18s var(--ease), transform 0.18s var(--ease);
  }
  .pg__run:hover { background: var(--accent-2); transform: translateY(-1px); }
  @media (max-width: 480px) { .pg__run { width: 100%; margin-top: 0.2rem; } }

  /* output block — bordered card, caption sits above it */
  .pg__out {
    color: var(--ink); font-family: var(--font-mono);
    font-size: 0.8rem; line-height: 1.75; padding: 1rem 1.1rem;
    min-height: 110px; max-height: 360px; overflow: auto; white-space: pre-wrap; word-break: break-word;
    border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--card);
  }
  .pg__hint { color: var(--ink-3); }
  .pg__out :global(.ok) { color: var(--ok); font-weight: 500; }
  .pg__out :global(.bad) { color: var(--accent); font-weight: 500; }
  .pg__out :global(.key) { color: #fff; background: var(--accent); padding: 0 0.2em; border-radius: 3px; }
  .pg__out :global(.dim) { color: var(--ink-3); }

  /* derived schema — full-width reference, doesn't affect the grid */
  .pg__schema { margin-top: 1rem; border: 1px solid var(--line); border-radius: var(--radius-sm); background: var(--card); overflow: hidden; }
  .pg__schema summary { cursor: pointer; font-family: var(--font-mono); font-size: 0.74rem; color: var(--ink-2); padding: 0.6rem 0.9rem; user-select: none; }
  .pg__schema summary:hover { color: var(--accent); }
  .pg__schema[open] summary { border-bottom: 1px solid var(--line); }
  .pg__code--schema :global(pre.astro-code) { font-size: 0.76rem; }
</style>

<script>
  import { __check, ValidationError } from '@dnssfnv/t12n/runtime'

  const schema = {
    kind: 'object',
    properties: {
      id: { kind: 'number' },
      name: { kind: 'string' },
      email: { kind: 'string' },
      role: { kind: 'enum', values: ['admin', 'user'] },
      address: { kind: 'object', properties: { zip: { kind: 'string' } } },
    },
  } as const

  const presets: Record<string, unknown> = {
    valid: { id: 1, name: 'Ada', email: 'ada@x.dev', role: 'admin', address: { zip: '00000' } },
    wrongType: { id: '1', name: 'Ada', email: 'ada@x.dev', role: 'admin', address: { zip: '00000' } },
    missing: { id: 1, name: 'Ada', role: 'user', address: { zip: '00000' } },
    extra: { id: 1, name: 'Ada', email: 'ada@x.dev', role: 'user', address: { zip: '00000' }, _internal: true, debug: 42 },
    multi: { id: 1, name: 2, email: null, role: 'root', address: { zip: 99 } },
  }

  const esc = (s: string) => s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]!))

  function init() {
    const root = document.querySelector<HTMLElement>('.pg')
    if (!root) return
    const ru = root.dataset.lang === 'ru'
    const input = root.querySelector<HTMLTextAreaElement>('.pg__input')!
    const out = root.querySelector<HTMLElement>('.pg__out')!

    const setData = (k: string) => { input.value = JSON.stringify(presets[k], null, 2) }
    if (!input.value.trim()) setData('valid')

    root.querySelectorAll<HTMLButtonElement>('.pg__presets button').forEach((b) => {
      b.onclick = () => { setData(b.dataset.preset!); run() }
    })
    root.querySelector<HTMLButtonElement>('.pg__run')!.onclick = run

    function run() {
      let data: unknown
      try {
        data = JSON.parse(input.value)
      } catch (e) {
        out.innerHTML = `<span class="bad">✗ ${ru ? 'не удалось разобрать JSON' : 'invalid JSON'}</span>\n<span class="dim">${esc((e as Error).message)}</span>`
        return
      }
      // Illustrative boundary meta — in a real build the plugin embeds the
      // actual file:line + boundary at each site; here we show a representative
      // one so the playground demonstrates t12n's source-located errors.
      const meta = { at: 'src/user.ts:7', b: 'fetch().json()' }
      try {
        const result = __check(data, schema as any, '(root)', meta)
        const stripped = JSON.stringify(data) !== JSON.stringify(result)
        out.innerHTML =
          `<span class="ok">✓ ${ru ? 'валидно' : 'valid'}</span>` +
          (stripped ? `  <span class="dim">${ru ? '— лишние ключи срезаны' : '— unknown keys stripped'}</span>` : '') +
          `\n${esc(JSON.stringify(result, null, 2))}`
        console.log('[t12n] ✓ valid', result)
      } catch (e) {
        if (e instanceof ValidationError) {
          const illus = ru ? 'для примера' : 'illustrative'
          const issues = e.issues && e.issues.length ? e.issues : [{ path: e.path, expected: e.expected, received: e.received }]
          const count = issues.length > 1 ? ` <span class="dim">— ${issues.length} ${ru ? 'проблемы' : 'issues'}</span>` : ''
          const block = (i: { path: string; expected: string; received: unknown }) =>
            `<span class="dim">${ru ? 'путь' : 'path'}</span>     <span class="key">${esc(i.path)}</span>\n` +
            `<span class="dim">${ru ? 'ожидалось' : 'expected'}</span> <span class="ok">${esc(i.expected)}</span>\n` +
            `<span class="dim">${ru ? 'пришло' : 'received'}</span>  <span class="bad">${esc(JSON.stringify(i.received))}</span>\n`
          out.innerHTML =
            `<span class="bad">✗ ValidationError</span>${count}\n` +
            (e.source ? `<span class="dim">${ru ? 'источник' : 'source'}</span>   <span class="key">${esc(e.source)}</span> <span class="dim">(${illus})</span>\n` : '') +
            (e.boundary ? `<span class="dim">${ru ? 'граница' : 'boundary'}</span>  ${esc(e.boundary)}\n` : '') +
            '\n' +
            issues.map(block).join('\n')
          console.warn('[t12n]', e.message)
        } else {
          out.innerHTML = `<span class="bad">✗ ${esc(String(e))}</span>`
        }
      }
    }
  }

  document.addEventListener('astro:page-load', init)
</script>
